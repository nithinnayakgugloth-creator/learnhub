# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/learnhub?retryWrites=true&w=majority

# Flask Secret Key (generate a random string for production)
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# Optional: Environment (development or production)
FLASK_ENV=production
